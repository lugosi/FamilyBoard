# Public URL where you open the app (no trailing slash). Required behind HTTPS or non-localhost.
# Must match an authorized redirect URI in Google Cloud: ${PUBLIC_APP_URL}/api/auth/google/callback
PUBLIC_APP_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: calendar to read/write (default: primary)
# GOOGLE_CALENDAR_ID=primary

# IANA timezone for new/edited events (default: UTC)
DEFAULT_TIMEZONE=America/Los_Angeles

# Open-Meteo (no API key)
WEATHER_LAT=37.77
WEATHER_LON=-122.42
# WEATHER_TIMEZONE=auto

# Hue bridge on your LAN
HUE_BRIDGE_IP=192.168.1.50
# Optional if you pair via the UI (stored under DATA_DIR/hue.json)
# HUE_USERNAME=

# Writable directory inside the container (mount a dataset here on TrueNAS)
DATA_DIR=/data

# Optional container listen port (for TrueNAS app edit). Keep in sync with your mapped container port.
APP_PORT=3000
