# Public URL where you open the app (no trailing slash). Required behind HTTPS or non-localhost.
# Must match an authorized redirect URI in Google Cloud: ${PUBLIC_APP_URL}/api/auth/google/callback
PUBLIC_APP_URL=http://localhost:3000

# OAuth client from Google Cloud Console (Web application). One client is used for Calendar + Nest.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Nest Device Access *enterprise* UUID (Device Access console → Project → ID). Not the OAuth client id.
# Nest setup usually forces a *new* OAuth client because Device Access must be tied to a GCP project:
#   1. Create/link a Google Cloud project in https://console.nest.google.com/device-access
#   2. Enable "Smart Device Management API" on that same GCP project
#   3. Create the OAuth client (ID + secret) in that project's Credentials — not an older Calendar-only project
#   4. Put the enterprise UUID here; put that client's ID/secret in GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above
# After switching clients, disconnect Google in the app and Link Google again (refresh token is per client).
GOOGLE_NEST_PROJECT_ID=
# Nest troubleshooting: GET /api/nest/debug (JSON) or Indoor widget → Debug button

# Spotify OAuth app credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: calendar to read/write (default: primary)
# GOOGLE_CALENDAR_ID=primary

# IANA timezone for new/edited events (default: UTC)
DEFAULT_TIMEZONE=America/Los_Angeles

# Open-Meteo (no API key)
WEATHER_LAT=37.77
WEATHER_LON=-122.42
# WEATHER_TIMEZONE=auto

# Hue bridge on your LAN
HUE_BRIDGE_IP=192.168.1.50
# Optional if you pair via the UI (stored under DATA_DIR/hue.json)
# HUE_USERNAME=

# Writable directory inside the container (mount a dataset here on TrueNAS)
DATA_DIR=/data

# Optional container listen port (for TrueNAS app edit). Keep in sync with your mapped container port.
APP_PORT=3000

